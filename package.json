{
  "name": "contact_book",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "A web app for browsing, editing, and exporting contacts stored in a PocketBase database.",
  "homepage": "https://github.com/JakeShirley/ContactBook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JakeShirley/ContactBook.git"
  },
